{
  "name": "@navigator/desktop",
  "version": "0.3.8",
  "private": true,
  "type": "module",
  "description": "Admin Desktop App",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "predev": "node scripts/predev.cjs",
    "dev": "node scripts/dev.cjs --local",
    "predev:clean": "node scripts/predev.cjs",
    "dev:clean": "node scripts/dev.cjs --local --clean",
    "predev:remote": "node scripts/predev.cjs",
    "dev:remote": "node scripts/dev.cjs --remote",
    "build:mcp-tools:dev": "node scripts/bundle-skills.cjs --mode=dev",
    "build:mcp-tools:package": "node scripts/bundle-skills.cjs --mode=package",
    "build:base": "pnpm -F @navigator/web build && tsc && vite build",
    "build": "pnpm build:base && pnpm build:mcp-tools:dev",
    "build:electron": "pnpm build:base && pnpm build:mcp-tools:package && node scripts/package.cjs",
    "build:unpack": "pnpm build:base && pnpm build:mcp-tools:package && node scripts/package.cjs --dir",
    "package": "pnpm download:nodejs && pnpm build:base && pnpm build:mcp-tools:package && node scripts/package.cjs --mac --publish never && npx electron-rebuild -f",
    "package:mac": "pnpm download:nodejs && pnpm build:base && pnpm build:mcp-tools:package && node scripts/package.cjs --mac --publish never && npx electron-rebuild -f",
    "package:win": "pnpm download:nodejs && pnpm build:base && pnpm build:mcp-tools:package && node scripts/package.cjs --win --x64 --publish never",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "node -e \"const fs=require('fs');['dist','dist-electron','release'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "download:nodejs": "node scripts/download-nodejs.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.971.0",
    "@aws-sdk/credential-providers": "^3.971.0",
    "@azure/identity": "^4.13.0",
    "@navigator_ai/agent-core": "workspace:*",
    "better-sqlite3": "catalog:",
    "dotenv": "^17.2.3",
    "electron-store": "^8.2.0",
    "grammy": "^1.41.1",
    "gray-matter": "^4.0.3",
    "node-pty": "catalog:",
    "opencode-ai": "1.2.10",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.2",
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vite-plugin-electron": "^0.29.0"
  },
  "optionalDependencies": {
    "opencode-darwin-arm64": "1.2.10",
    "opencode-darwin-x64": "1.2.10",
    "opencode-darwin-x64-baseline": "1.2.10"
  },
  "build": {
    "npmRebuild": false,
    "compression": "normal",
    "appId": "ai.navigator.desktop",
    "productName": "Admin (formerly Openwork)",
    "artifactName": "Admin-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist-electron/**/*",
      "node_modules/opencode-ai/**",
      "node_modules/opencode-darwin-arm64/**",
      "node_modules/opencode-darwin-x64/**",
      "node_modules/opencode-darwin-x64-baseline/**",
      "node_modules/node-pty/**",
      "node_modules/electron-store/**",
      "node_modules/conf/**",
      "node_modules/env-paths/**",
      "node_modules/json-schema-typed/**",
      "node_modules/atomically/**",
      "node_modules/debounce-fn/**",
      "!node_modules/@accomplish_ai/**",
      "!node_modules/opencode-linux-*/**"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../../packages/agent-core/mcp-tools",
        "to": "mcp-tools",
        "filter": [
          "**/*",
          "!**/profiles/**",
          "!**/tmp/**",
          "!**/.git/**",
          "!**/.browser-data/**",
          "!**/.ignored_*/**",
          "!**/bun.lock",
          "!**/*.test.ts",
          "!**/vitest.config.ts"
        ]
      },
      {
        "from": "../web/dist/client",
        "to": "web-ui"
      },
      {
        "from": "bundled-skills",
        "to": "bundled-skills",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/opencode-ai/bin/opencode",
      "node_modules/opencode-ai/bin/opencode.exe",
      "node_modules/opencode-ai/package.json",
      "node_modules/opencode-darwin-arm64/bin/opencode",
      "node_modules/opencode-darwin-arm64/package.json",
      "node_modules/opencode-darwin-x64/bin/opencode",
      "node_modules/opencode-darwin-x64/package.json",
      "node_modules/opencode-darwin-x64-baseline/bin/opencode",
      "node_modules/opencode-darwin-x64-baseline/package.json",
      "node_modules/opencode-windows-x64/bin/opencode.exe",
      "node_modules/opencode-windows-x64/package.json",
      "node_modules/opencode-windows-x64-baseline/bin/opencode.exe",
      "node_modules/opencode-windows-x64-baseline/package.json",
      "node_modules/node-pty/build/**/*.node",
      "node_modules/node-pty/package.json",
      "node_modules/better-sqlite3/build/**/*.node",
      "node_modules/better-sqlite3/package.json",
      "dist-electron/main/mcp/*.js"
    ],
    "afterPack": "./scripts/after-pack.cjs",
    "publish": {
      "provider": "github",
      "owner": "navigator-ai",
      "repo": "navigator"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "icon": "resources/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Admin",
      "runAfterFinish": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
